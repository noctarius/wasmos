# wasmos: WARP JIT (ring 3), SMP
CONFIG_AS_ENABLE=y
CONFIG_RUST_ENABLE=y
CONFIG_GO_ENABLE=y
CONFIG_ZIG_ENABLE=y
CONFIG_WASMOS_TRACE=n
CONFIG_WASMOS_RING3_SMOKE=n
CONFIG_WASMOS_RING3_THREAD_LIFECYCLE_SMOKE=n
CONFIG_WASMOS_PM_TEST_HOOKS=n
CONFIG_WASMOS_PM_LIST_LINKED=y
CONFIG_WASMOS_PM_LIST_ARRAY_CHUNK=n
CONFIG_WASMOS_PM_LIST_ARRAY_CHUNK_CAP=16
CONFIG_WASMOS_IRQ_PIC=n
CONFIG_WASMOS_IRQ_LAPIC=n
CONFIG_WASMOS_IRQ_IOAPIC=y
CONFIG_KERNEL_TARGET_TRIPLE="x86_64-elf"
CONFIG_QEMU_GDB_PORT=1234
