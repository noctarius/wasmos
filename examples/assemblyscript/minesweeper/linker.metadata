version = 1

[package]
name = "Minesweeper"
entry = "wasmos_main"
kind = "app"
native = false

[resources]
stack_pages = 8
heap_pages = 128

[ipc]
required_endpoint_name = "proc"
required_endpoint_rights = 0
entry_arg_bindings = ["proc.endpoint"]

[[capabilities]]
name = "ipc.basic"
flags = 0

[[capabilities]]
name = "dma.buffer"
flags = 0
