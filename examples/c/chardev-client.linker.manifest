version = 1

[package]
name = "chardev-client"
entry = "wasmos_main"
kind = "app"
native = false

[resources]
stack_pages = 16
heap_pages = 16

[ipc]
required_endpoint_name = "chardev"
required_endpoint_rights = 1
entry_arg_bindings = ["chardev.endpoint"]

[[capabilities]]
name = "ipc.basic"
flags = 0
