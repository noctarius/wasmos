# WASMOS device-manager persistent rules (boot FAT)
# Loaded from /boot/system/devmgr/rules after storage is online.
# Entries here are intended to override or extend initfs bootstrap rules.
always_spawn spawn_path=system/drivers/ata.wap
always_spawn spawn_path=system/drivers/keyboard.wap
pci_framebuffer class=03 spawn_path=system/drivers/fbpci.wap
block_fs unit=0 mount=/boot spawn_path=system/drivers/fs_fat.wap
block_fs unit=1 mount=/user spawn_path=system/drivers/fs_fat.wap
