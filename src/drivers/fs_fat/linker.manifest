version = 1

[package]
name = "fs-fat"
entry = "initialize"
kind = "driver"
native = false

[resources]
stack_pages = 16
heap_pages = 16

[ipc]
required_endpoint_name = "block"
required_endpoint_rights = 1
entry_arg_bindings = ["proc.endpoint", "block.endpoint"]

[[capabilities]]
name = "ipc.basic"
flags = 0
