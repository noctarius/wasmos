#pragma once
/* compat/atomic — freestanding stub of <atomic>
 *
 * WARP uses std::atomic_thread_fence to ensure memory ordering around JIT
 * code emission.  We map this to the GCC/clang built-in __sync_synchronize()
 * which emits a full memory barrier (MFENCE on x86_64).
 *
 * A minimal std::atomic<T> is also provided for any load/store uses;
 * it uses __atomic_* built-ins which are always available in clang. */

namespace std {

// ---------------------------------------------------------------------------
// memory_order enum
// ---------------------------------------------------------------------------

enum memory_order {
    memory_order_relaxed = 0,
    memory_order_consume = 1,
    memory_order_acquire = 2,
    memory_order_release = 3,
    memory_order_acq_rel = 4,
    memory_order_seq_cst = 5,
};

// ---------------------------------------------------------------------------
// atomic_thread_fence / atomic_signal_fence
// ---------------------------------------------------------------------------

inline void atomic_thread_fence(memory_order) noexcept {
    __sync_synchronize();
}

inline void atomic_signal_fence(memory_order) noexcept {
    /* Compiler barrier only — no hardware fence needed for signal context. */
    __asm__ volatile("" ::: "memory");
}

// ---------------------------------------------------------------------------
// atomic<T> — load/store/exchange subset via __atomic built-ins
// ---------------------------------------------------------------------------

template <typename T>
class atomic {
public:
    atomic() noexcept = default;
    constexpr atomic(T desired) noexcept : _val(desired) {}

    /* Not copyable. */
    atomic(const atomic &) = delete;
    atomic &operator=(const atomic &) = delete;
    atomic &operator=(const atomic &) volatile = delete;

    T load(memory_order = memory_order_seq_cst) const noexcept {
        T ret;
        __atomic_load(&_val, &ret, __ATOMIC_SEQ_CST);
        return ret;
    }

    void store(T desired, memory_order = memory_order_seq_cst) noexcept {
        __atomic_store(&_val, &desired, __ATOMIC_SEQ_CST);
    }

    T exchange(T desired, memory_order = memory_order_seq_cst) noexcept {
        T ret;
        __atomic_exchange(&_val, &desired, &ret, __ATOMIC_SEQ_CST);
        return ret;
    }

    bool compare_exchange_strong(T &expected, T desired,
                                 memory_order = memory_order_seq_cst,
                                 memory_order = memory_order_seq_cst) noexcept {
        return __atomic_compare_exchange(&_val, &expected, &desired,
                                         /*weak=*/false,
                                         __ATOMIC_SEQ_CST, __ATOMIC_SEQ_CST);
    }

    bool compare_exchange_weak(T &expected, T desired,
                               memory_order = memory_order_seq_cst,
                               memory_order = memory_order_seq_cst) noexcept {
        return __atomic_compare_exchange(&_val, &expected, &desired,
                                         /*weak=*/true,
                                         __ATOMIC_SEQ_CST, __ATOMIC_SEQ_CST);
    }

    T operator=(T desired) noexcept { store(desired); return desired; }
    operator T() const noexcept { return load(); }

    bool is_lock_free() const noexcept { return __atomic_is_lock_free(sizeof(T), &_val); }

private:
    T _val;
};

/* Convenience typedefs for the most common atomic integer sizes. */
using atomic_bool    = atomic<bool>;
using atomic_int     = atomic<int>;
using atomic_uint    = atomic<unsigned int>;
using atomic_int32_t = atomic<int>;
using atomic_uint32_t= atomic<unsigned int>;

} // namespace std
