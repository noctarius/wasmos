#pragma once
/* Minimal <memory> stub — provides std::unique_ptr needed by MemWriter.cpp.
 * No allocator customization; uses operator new/delete from cxx_abi.cpp. */
#include "type_traits"
#include "utility"

namespace std {

template<class T>
struct default_delete {
    void operator()(T *p) const noexcept { delete p; }
};
template<class T>
struct default_delete<T[]> {
    void operator()(T *p) const noexcept { delete[] p; }
};

template<class T, class D = default_delete<T>>
class unique_ptr {
    T *ptr_ = nullptr;
    D  del_;
public:
    using pointer      = T *;
    using element_type = T;
    using deleter_type = D;

    constexpr unique_ptr() noexcept = default;
    constexpr unique_ptr(decltype(nullptr)) noexcept : ptr_(nullptr) {}
    explicit  unique_ptr(T *p) noexcept : ptr_(p) {}
    unique_ptr(unique_ptr &&o) noexcept : ptr_(o.release()), del_(move(o.del_)) {}
    unique_ptr(const unique_ptr &) = delete;
    ~unique_ptr() noexcept { if (ptr_) del_(ptr_); }

    unique_ptr &operator=(unique_ptr &&o) noexcept {
        if (this != &o) { reset(o.release()); del_ = move(o.del_); }
        return *this;
    }
    unique_ptr &operator=(decltype(nullptr)) noexcept { reset(); return *this; }
    unique_ptr &operator=(const unique_ptr &) = delete;

    T *get()    const noexcept { return ptr_; }
    T *release() noexcept { T *p = ptr_; ptr_ = nullptr; return p; }
    void reset(T *p = nullptr) noexcept { if (ptr_) del_(ptr_); ptr_ = p; }
    void swap(unique_ptr &o) noexcept { T *t = ptr_; ptr_ = o.ptr_; o.ptr_ = t; }

    T &operator*()  const noexcept { return *ptr_; }
    T *operator->() const noexcept { return ptr_; }
    explicit operator bool() const noexcept { return ptr_ != nullptr; }
    bool operator==(decltype(nullptr)) const noexcept { return !ptr_; }
    bool operator!=(decltype(nullptr)) const noexcept { return  ptr_; }
};

template<class T, class... Args>
unique_ptr<T> make_unique(Args&&... args) {
    return unique_ptr<T>(new T(forward<Args>(args)...));
}

// addressof — returns address of object regardless of operator& overload
template<class T>
T *addressof(T &r) noexcept { return __builtin_addressof(r); }

// std::align — adjusts ptr and space for alignment
inline void *align(size_t alignment, size_t size, void *&ptr, size_t &space) noexcept {
    uintptr_t p = reinterpret_cast<uintptr_t>(ptr);
    uintptr_t aligned = (p + alignment - 1u) & ~(alignment - 1u);
    size_t offset = static_cast<size_t>(aligned - p);
    if (offset + size > space) return nullptr;
    space -= offset;
    ptr = reinterpret_cast<void *>(aligned);
    return ptr;
}

} // namespace std
