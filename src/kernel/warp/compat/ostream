#pragma once
/* Minimal <ostream> stub — satisfies WARP's #include <ostream> and the
 * &std::endl references in MemUtils.cpp.  Never actually used at runtime
 * since we stub the calls that would print. */
namespace std {
struct ostream {
    template<class T> ostream &operator<<(T const &) noexcept { return *this; }
    ostream &operator<<(ostream &(*)(ostream &)) noexcept { return *this; }
};
inline ostream &endl(ostream &os) noexcept { return os; }
inline ostream &flush(ostream &os) noexcept { return os; }
} // namespace std
