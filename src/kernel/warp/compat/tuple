#pragma once
/* compat/tuple — freestanding shadow of <tuple>
 *
 * Provides: std::tuple<Ts...>, std::tuple_size<T>, std::tuple_element<N,T>,
 *           std::get<N>(t).
 *
 * Implementation uses recursive inheritance (the classical approach that does
 * not require compiler intrinsics and works in C++14).
 *
 * Only the subset required by WARP is implemented; in particular there is no
 * std::apply, std::tie, or structured-binding support. */

#include "type_traits"
#include "utility"
#include <stddef.h>

namespace std {

// ---------------------------------------------------------------------------
// Forward declarations
// ---------------------------------------------------------------------------

template <typename... Ts> class tuple;

// ---------------------------------------------------------------------------
// tuple_size
// ---------------------------------------------------------------------------

template <typename T>             struct tuple_size;            // undefined base
template <typename T>             struct tuple_size<const T> : tuple_size<T> {};
template <typename T>             struct tuple_size<volatile T> : tuple_size<T> {};
template <typename T>             struct tuple_size<const volatile T> : tuple_size<T> {};

template <typename... Ts>
struct tuple_size<tuple<Ts...>>
    : integral_constant<size_t, sizeof...(Ts)> {};

// ---------------------------------------------------------------------------
// tuple_element
// ---------------------------------------------------------------------------

template <size_t N, typename T> struct tuple_element;           // undefined base

namespace detail {

/* Recursive list walk: peel one type per step. */
template <size_t N, typename Head, typename... Tail>
struct tuple_element_impl {
    using type = typename tuple_element_impl<N-1, Tail...>::type;
};

template <typename Head, typename... Tail>
struct tuple_element_impl<0, Head, Tail...> {
    using type = Head;
};

} // namespace detail

template <size_t N, typename... Ts>
struct tuple_element<N, tuple<Ts...>> {
    static_assert(N < sizeof...(Ts), "tuple_element: index out of range");
    using type = typename detail::tuple_element_impl<N, Ts...>::type;
};

template <size_t N, typename T>
struct tuple_element<N, const T> { using type = const typename tuple_element<N,T>::type; };

template <size_t N, typename T>
using tuple_element_t = typename tuple_element<N,T>::type;

// ---------------------------------------------------------------------------
// Recursive storage base
// ---------------------------------------------------------------------------

namespace detail {

/* TupleLeaf holds a single element at index I. */
template <size_t I, typename T>
struct TupleLeaf {
    T value;
    constexpr TupleLeaf() : value() {}
    constexpr explicit TupleLeaf(const T &v) : value(v) {}
    template <typename U>
    constexpr explicit TupleLeaf(U &&v) : value(forward<U>(v)) {}
};

/* TupleImpl recursively inherits from TupleLeaf for each element. */
template <size_t I, typename... Ts> struct TupleImpl;

template <size_t I>
struct TupleImpl<I> {};

template <size_t I, typename Head, typename... Tail>
struct TupleImpl<I, Head, Tail...>
    : TupleLeaf<I, Head>, TupleImpl<I+1, Tail...>
{
    constexpr TupleImpl() = default;

    template <typename H, typename... T>
    constexpr TupleImpl(H &&h, T &&...t)
        : TupleLeaf<I, Head>(forward<H>(h))
        , TupleImpl<I+1, Tail...>(forward<T>(t)...) {}
};

/* Accessor: get the leaf at index N from a TupleImpl. */
template <size_t N, size_t I, typename Head, typename... Tail>
struct GetImpl {
    static constexpr auto &get(TupleImpl<I, Head, Tail...> &ti) noexcept {
        return GetImpl<N, I+1, Tail...>::get(
            static_cast<TupleImpl<I+1, Tail...>&>(ti));
    }
    static constexpr const auto &get(const TupleImpl<I, Head, Tail...> &ti) noexcept {
        return GetImpl<N, I+1, Tail...>::get(
            static_cast<const TupleImpl<I+1, Tail...>&>(ti));
    }
};

template <size_t I, typename Head, typename... Tail>
struct GetImpl<I, I, Head, Tail...> {
    static constexpr Head &get(TupleImpl<I, Head, Tail...> &ti) noexcept {
        return static_cast<TupleLeaf<I, Head>&>(ti).value;
    }
    static constexpr const Head &get(const TupleImpl<I, Head, Tail...> &ti) noexcept {
        return static_cast<const TupleLeaf<I, Head>&>(ti).value;
    }
};

} // namespace detail

// ---------------------------------------------------------------------------
// tuple
// ---------------------------------------------------------------------------

template <typename... Ts>
class tuple : private detail::TupleImpl<0, Ts...> {
    using Base = detail::TupleImpl<0, Ts...>;

    /* Allow std::get to reach private base. */
    template <size_t N, typename... Us>
    friend constexpr tuple_element_t<N, tuple<Us...>> &
    get(tuple<Us...> &t) noexcept;

    template <size_t N, typename... Us>
    friend constexpr const tuple_element_t<N, tuple<Us...>> &
    get(const tuple<Us...> &t) noexcept;

public:
    constexpr tuple() = default;

    template <typename... Args>
    constexpr explicit tuple(Args &&...args)
        : Base(forward<Args>(args)...) {}

    tuple(const tuple &) = default;
    tuple(tuple &&)      = default;

    tuple &operator=(const tuple &) = default;
    tuple &operator=(tuple &&)      = default;
};

/* Empty tuple specialisation. */
template <>
class tuple<> {};

// ---------------------------------------------------------------------------
// std::get<N>(tuple)
// ---------------------------------------------------------------------------

template <size_t N, typename... Ts>
constexpr tuple_element_t<N, tuple<Ts...>> &
get(tuple<Ts...> &t) noexcept {
    return detail::GetImpl<N, 0, Ts...>::get(
        static_cast<detail::TupleImpl<0, Ts...>&>(t));
}

template <size_t N, typename... Ts>
constexpr const tuple_element_t<N, tuple<Ts...>> &
get(const tuple<Ts...> &t) noexcept {
    return detail::GetImpl<N, 0, Ts...>::get(
        static_cast<const detail::TupleImpl<0, Ts...>&>(t));
}

// ---------------------------------------------------------------------------
// make_tuple
// ---------------------------------------------------------------------------

template <typename... Ts>
constexpr tuple<typename decay<Ts>::type...>
make_tuple(Ts &&...args) {
    return tuple<typename decay<Ts>::type...>(forward<Ts>(args)...);
}

} // namespace std
