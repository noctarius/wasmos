version = 1

[package]
name = "cli"
entry = "initialize"
kind = "service"
native = false

[resources]
stack_pages = 16
heap_pages = 16

[ipc]
required_endpoint_name = "proc"
required_endpoint_rights = 1
entry_arg_bindings = ["proc.endpoint", "cli.tty.alloc"]

[[capabilities]]
name = "system.control"
flags = 0
