version = 1

[package]
name = "sysinit"
entry = "initialize"
kind = "service"
native = false

[resources]
stack_pages = 64
heap_pages = 64

[ipc]
required_endpoint_name = "proc"
required_endpoint_rights = 1
entry_arg_bindings = ["proc.endpoint", "module.count", "init.module.index"]

[[capabilities]]
name = "ipc.basic"
flags = 0
